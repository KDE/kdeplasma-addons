msgstr[0] "%1 ден"
msgstr[1] "%1 дни"

#: config/qml/AlternateCalendarConfig.qml:91
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"A positive offset signifies a later date, while a negative offset signifies "
"an earlier date."
msgstr ""
"Положително отместване означава по-късна дата, а отрицателно отместване "
"означава по-ранна дата."

