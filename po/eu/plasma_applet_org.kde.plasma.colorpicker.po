#: qml/ColorCircle.qml:26
#, kde-format
msgctxt "@info"
msgid "No Saved Colors"
msgstr "Gordetako kolorerik ez"

#: qml/ColorCircle.qml:40
#, kde-format
msgctxt "@info:usagetip"
msgid "Middle-click to copy the color code"
msgstr "Erdiko-klik kolore-kodea kopiatzeko"

#: qml/CompactRepresentation.qml:79
#, kde-format
msgctxt "@info:tooltip"
msgid "Pick color"
msgstr "Hautatu kolore bat"

#: qml/CompactRepresentation.qml:86
#, kde-kuit-format
msgctxt "@info:usagetip"
msgid ""
"Drag a color code here to save it<nl/>Drag an image file here to get its "
"average color"
msgstr ""
"Arrastatu kolore-kode bat horra hura gordetzeko<nl/>Arrastatu irudi-"
"fitxategi bat horra bere batezbesteko kolorea lortzeko"

