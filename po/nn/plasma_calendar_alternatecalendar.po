#: config/qml/AlternateCalendarConfig.qml:48
#, kde-format
msgctxt "@label:listbox"
msgid "Calendar system:"
msgstr "Kalendersystem:"

#: config/qml/AlternateCalendarConfig.qml:69
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"This calendar is based on pure astronomical calculation. It doesn't consider "
"any crescent visibility criteria."
msgstr ""
"Denne kalenderen er berre basert på astronomiske utrekningar. Han tek ikkje "
"omsyn til når månen faktisk vert synleg."

#: config/qml/AlternateCalendarConfig.qml:77
#, kde-format
msgctxt "@label:spinbox"
msgid "Date offset:"
msgstr "Dato-forskyving:"

#: config/qml/AlternateCalendarConfig.qml:88
#, kde-format
msgid "%1 day"
msgid_plural "%1 days"
msgstr[0] "%1 dag"
msgstr[1] "%1 dagar"

#: config/qml/AlternateCalendarConfig.qml:91
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"A positive offset signifies a later date, while a negative offset signifies "
"an earlier date."
msgstr ""
"Tal større enn null svarar til ein seinare dato, tal mindre enn null til ein "
"tidlegare."

