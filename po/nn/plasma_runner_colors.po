#: colorsrunner.cpp:29
#, kde-format
msgid ""
"Displays the value of :q: as a color when :q: is a hexadecimal color (e.g. "
"#FF00FF) or an SVG named color."
msgstr ""
"Viser verdien av :q: som ein farge når :q: er ein heksadesimal-kode "
"(eks. #FF00FF) eller namnet på ein SVG-farge."

#: colorsrunner.cpp:31
#, kde-format
msgid ""
"Displays the value of :q: as a color when :q: is an RGB color triplet (e.g. "
"255,255,255)."
msgstr ""
"Viser verdien av :q: som ein farge når :q: er ein RGB-kode "
"(eks. 255,255,255)."

#: colorsrunner.cpp:34
#, kde-format
msgid ""
"Displays the value of :q: as a color with alpha channel when :q: is an RGBA "
"color quadruplet (e.g. 255,255,255,255)."
msgstr ""
"Viser verdien av :q: som ein farge med alfakanal når :q: er ein RGBA-kode "
"(eks. 255,255,255,255)."

#: colorsrunner.cpp:139
#, kde-format
msgid "RGBA: %1, %2, %3, %4"
msgstr "RGBA: %1, %2, %3, %4"

#: colorsrunner.cpp:141
#, kde-format
msgid "RGB: %1, %2, %3"
msgstr "RGB: %1, %2, %3"

#: colorsrunner.cpp:146
#, kde-format
msgid "CMYK: %1%, %2%, %3%, %4%"
msgstr "CMYK: %1 %, %2 %, %3 %, %4 %"
